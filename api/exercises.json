  {
    "name": "Shoulder Shrugs",
    "position": "seated",
    "tags": ["posture", "shoulders"],
    "desc": "Raise both shoulders up toward your ears, hold 3 seconds, then drop.",
    "phases": [
      {"label": "10 shrugs — up, hold 3s, drop", "seconds": 45}
    ]
  },
  {
    "name": "Chest Opener",
    "position": "standing",
    "tags": ["posture", "breathing"],
    "desc": "Clasp hands behind your back, straighten arms, and lift gently while squeezing shoulder blades together.",
    "phases": [
      {"label": "Hold — squeeze shoulder blades", "seconds": 20},
      {"label": "Relax", "seconds": 5},
      {"label": "Hold again — go deeper", "seconds": 20},
      {"label": "Relax", "seconds": 5},
      {"label": "Final hold", "seconds": 20}
    ]
  },
  {
    "name": "Seated Spinal Twist",
    "position": "seated",
    "tags": ["mobility", "spine"],
    "desc": "Sitting up straight, twist to one side with your opposite hand on your knee.",
    "phases": [
      {"label": "Twist right — hold", "seconds": 15},
      {"label": "Return to center", "seconds": 3},
      {"label": "Twist left — hold", "seconds": 15},
      {"label": "Return to center", "seconds": 3},
      {"label": "Twist right — deeper", "seconds": 15},
      {"label": "Return to center", "seconds": 3},
      {"label": "Twist left — deeper", "seconds": 15}
    ]
  },
  {
    "name": "Wrist Circles",
    "position": "seated",
    "tags": ["mobility", "wrists"],
    "desc": "Extend arms forward, make fists, and circle your wrists.",
    "phases": [
      {"label": "Circle outward — 10 times", "seconds": 15},
      {"label": "Switch direction", "seconds": 3},
      {"label": "Circle inward — 10 times", "seconds": 15}
    ]
  },
  {
    "name": "Standing Quad Stretch",
    "position": "standing",
    "tags": ["flexibility", "legs"],
    "desc": "Stand on one leg, pull the other foot toward your glute. Use a wall for balance.",
    "phases": [
      {"label": "Left leg — hold", "seconds": 20},
      {"label": "Switch legs", "seconds": 5},
      {"label": "Right leg — hold", "seconds": 20}
    ]
  },
  {
    "name": "Calf Raises",
    "position": "standing",
    "tags": ["mobility", "ankles"],
    "desc": "Stand with feet hip-width apart. Rise onto your toes, hold 2 seconds, lower slowly.",
    "phases": [
      {"label": "15 reps — rise, hold 2s, lower", "seconds": 45}
    ]
  },
  {
    "name": "Hip Flexor Stretch",
    "position": "floor",
    "tags": ["flexibility", "hips"],
    "desc": "Step one foot forward into a lunge, drop the back knee to the floor. Push hips forward gently.",
    "phases": [
      {"label": "Left side — push hips forward", "seconds": 30},
      {"label": "Switch sides", "seconds": 5},
      {"label": "Right side — push hips forward", "seconds": 30}
    ]
  },
  {
    "name": "Cat-Cow",
    "position": "floor",
    "tags": ["mobility", "spine"],
    "desc": "On all fours, arch your back up (cat), then dip it down (cow). Move slowly with your breath.",
    "phases": [
      {"label": "10 cycles — arch up, dip down, breathe", "seconds": 60}
    ]
  },
  {
    "name": "Wall Angels",
    "position": "standing",
    "tags": ["posture", "shoulders"],
    "desc": "Stand with back flat against a wall, arms in goalpost position. Slide arms up and down slowly.",
    "phases": [
      {"label": "10 reps — slide up, slide down", "seconds": 60}
    ]
  },
  {
    "name": "Figure-4 Stretch",
    "position": "seated",
    "tags": ["flexibility", "hips"],
    "desc": "Sit in a chair, cross one ankle over the opposite knee. Lean forward gently until you feel a stretch.",
